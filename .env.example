# ── Prod indexing (send evidence to the ISO index dashboard's GraphRAG) ──────
# Point Sentinel at the prod Next API base that proxies to GraphRAG:
UPSTREAM_API_URL=https://quanterra.eastus.cloudapp.azure.com/iso-man/api/graphrag

# Keycloak service client (client_credentials) — server mints a fresh token per
# request, so there is no cookie/token expiry to babysit. Create a dedicated
# confidential client (e.g. sentinel-service) with Service Accounts enabled and
# a role the /api/graphrag middleware accepts.
KEYCLOAK_BASE_URL=https://quanterra.eastus.cloudapp.azure.com/auth
KEYCLOAK_REALM=quanterra
KEYCLOAK_CLIENT_ID=sentinel-service
KEYCLOAK_CLIENT_SECRET=__set_me__
# Optional explicit token endpoint (otherwise derived from BASE+REALM):
# KEYCLOAK_TOKEN_URL=

# Short-lived manual fallbacks (instead of a service client):
# UPSTREAM_AUTH=Bearer eyJ...
# UPSTREAM_COOKIE=kc_access=...; kc_refresh=...

# ── Or talk straight to a reachable GraphRAG (e.g. ngrok) ────────────────────
# GRAPHRAG_API_URL=https://xxxx.ngrok-free.dev

# ── Optional: local persistence + AI evaluation (not required for prod flow) ──
# DATABASE_URL=postgresql://user:pass@host:5432/db
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_BASE_URL=https://<resource>.cognitiveservices.azure.com/openai/deployments/gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# Set none of the above → fully self-contained demo mode.
